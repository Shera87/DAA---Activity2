class Solution(object):
    def subarraySum(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        count = 0
        curr_sum = 0
        # prefix_sums map: { prefix_sum : frequency }
        # Initialize with 0:1 to handle subarrays that start from index 0
        prefix_sums = {0: 1}
        
        for n in nums:
            curr_sum += n
            
            # Check if (curr_sum - k) exists in the map
            diff = curr_sum - k
            if diff in prefix_sums:
                count += prefix_sums[diff]
            
            # Update the frequency of the current prefix sum in the map
            prefix_sums[curr_sum] = prefix_sums.get(curr_sum, 0) + 1
            
        return count
